{
  "name": "@cogni/node-template-root",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.2",
  "scripts": {
    "build": "pnpm build:packages && pnpm build:app",
    "build:packages": "pnpm -r --if-present --filter \"./packages/**\" --filter \"./graphs\" build && tsc -b packages/*/tsconfig.json packages/langgraph-graphs/tsconfig.build.json packages/doltgres-schema/tsconfig.json",
    "packages:build": "pnpm build:packages",
    "build:app": "pnpm --filter @cogni/node-template-app build",
    "check:workflow": "node scripts/check-node-ci-workflow.mjs",
    "conductor:setup": "bash scripts/conductor-worktree-setup.sh",
    "db:generate": "tsx node_modules/drizzle-kit/bin.cjs generate --config=drizzle.config.ts",
    "db:check": "pnpm db:check:drizzle && pnpm db:check:generate-clean",
    "db:check:drizzle": "DATABASE_URL=postgres://check@localhost:0/check tsx node_modules/drizzle-kit/bin.cjs check --config=drizzle.config.ts",
    "db:check:generate-clean": "node scripts/db/check-generate-clean.mjs",
    "db:migrate:direct": "tsx node_modules/drizzle-kit/bin.cjs migrate --config=drizzle.config.ts",
    "typecheck": "pnpm --filter @cogni/node-template-graphs typecheck && pnpm --filter @cogni/node-template-doltgres-schema typecheck && pnpm --filter @cogni/node-template-app typecheck",
    "test": "pnpm --filter @cogni/node-template-graphs test && pnpm --filter @cogni/node-template-app test",
    "test:ci": "pnpm test",
    "test:component": "pnpm --filter @cogni/node-template-app test:component",
    "check": "pnpm check:workflow && pnpm db:check && pnpm packages:build && pnpm typecheck && pnpm test:ci"
  },
  "pnpm": {
    "overrides": {
      "@assistant-ui/react": "0.12.10",
      "@assistant-ui/react-ai-sdk": "1.3.7",
      "@assistant-ui/react-data-stream": "0.12.4",
      "@assistant-ui/react-markdown": "0.12.3"
    }
  },
  "devDependencies": {
    "@types/node": "^22",
    "drizzle-kit": "^0.31.7",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "yaml": "^2.8.3"
  }
}
