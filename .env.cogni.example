# .env.cogni — your two Cogni agent accounts (copy to .env.cogni; gitignored via .env*).
#   NODE     = this node's own hub (https://<slug>.cognidao.org): the primary plane
#              for knowledge + interaction. Session cognition recalls it.
#   OPERATOR = cognidao.org: CI/CD only — flight, deploy, secrets.
# Mint each: POST <baseUrl>/api/v1/agent/register {"name":"<workspace>"}.
# Full runbook (register, access-request, RBAC): knowledge `node-launch-handoff`.

# ── NODE account (primary) ──
COGNI_NODE_API_KEY=
COGNI_NODE_USER_ID=
COGNI_NODE_BILLING_ACCOUNT=
COGNI_NODE_ID=

# ── OPERATOR account (CI/CD) ──
COGNI_OPERATOR_API_KEY=
COGNI_OPERATOR_USER_ID=
COGNI_OPERATOR_BILLING_ACCOUNT=
